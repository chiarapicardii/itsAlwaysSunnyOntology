@prefix : <https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#> .
@prefix dul: <http://www.loa-cnr.it/ontologies/DUL.owl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl> .

<https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl> rdf:type owl:Ontology ;
                                                                                                 owl:imports <http://www.loa-cnr.it/ontologies/DUL.owl> ;
                                                                                                 rdfs:comment "itsAlwaysSunnyOntology url: \"https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl\"" .

#################################################################
#    Object Properties
#################################################################

###  http://www.loa-cnr.it/ontologies/DUL.owl#isDescribedBy
dul:isDescribedBy owl:equivalentProperty :isDescribedBy .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#describes
:describes rdf:type owl:ObjectProperty ;
           owl:inverseOf :isDescribedBy .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#hasAgent
:hasAgent rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf dul:hasParticipant ;
          owl:inverseOf :isAgentIn ;
          rdfs:domain :HumorousSituation ;
          rdfs:range :Agent .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#hasQuality
:hasQuality rdf:type owl:ObjectProperty ;
            rdfs:domain :HumorEntity ;
            rdfs:range :HumorQuality ;
            rdfs:comment "connecting HumorQuality to HumorEntity" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#hasTarget
:hasTarget rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf dul:hasParticipant ;
           owl:inverseOf :isTargetIn ;
           rdfs:domain :HumorousSituation ;
           rdfs:range :Target .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#includes
:includes rdf:type owl:ObjectProperty ;
          owl:inverseOf :isIncludedIn ;
          rdf:type owl:TransitiveProperty ;
          rdfs:comment "This is the shape to model the inclusion for the blending, but as i understood is not possibile to use the same property for D&S seeing that one is a construction of a patter and the other of the real application of it" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#includesDescription
:includesDescription rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf dul:hasComponent ,
                                        :includes ;
                     rdfs:domain :HumorousFrame ;
                     rdfs:range :EthicalRule ,
                                :ExpectedSocialFrame ,
                                :SubversiveFrame ;
                     rdfs:comment "All the elements that, blended, make the DescriptionFrame of the humor" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#includesSituation
:includesSituation rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf dul:hasComponent ,
                                      :includes ;
                   rdfs:domain :HumorousSituation ;
                   rdfs:range :NormOccurence ,
                              :SubversiveOccurence ;
                   rdfs:comment "The actual application in the situation of the blending of the elements" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#isAgentIn
:isAgentIn rdf:type owl:ObjectProperty .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#isDescribedBy
:isDescribedBy rdf:type owl:ObjectProperty ;
               rdfs:domain :Situation ;
               rdfs:range :Description ;
               rdfs:comment "Important to connect the situations with the corresponding descriptions" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#isExplainedBy
:isExplainedBy rdf:type owl:ObjectProperty ;
               rdfs:domain :HumorousSituation ;
               rdfs:range :TheoreticalMechanism .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#isIncludedIn
:isIncludedIn rdf:type owl:ObjectProperty .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#isTargetIn
:isTargetIn rdf:type owl:ObjectProperty .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#isTriggeredBy
:isTriggeredBy rdf:type owl:ObjectProperty ;
               rdfs:domain :TheoreticalMechanism ;
               rdfs:range :SubversiveOccurence ;
               rdfs:comment "TheoreticalMechanism to Subversion" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#isViolatedBy
:isViolatedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf :violates .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#violates
:violates rdf:type owl:ObjectProperty ;
          rdfs:domain :SubversiveOccurence ;
          rdfs:range :NormOccurence ;
          rdfs:comment "connecting SubversiveOccurrence to NormOccurence" .


#################################################################
#    Data properties
#################################################################

###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#hasDescription
:hasDescription rdf:type owl:DatatypeProperty ;
                rdfs:domain :Situation ;
                rdfs:range xsd:string ;
                rdfs:comment "Description of the scene" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#hasEpisodeNumber
:hasEpisodeNumber rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Situation ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "Episode number with the season: for ex. S01E09" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#hasTimestamp
:hasTimestamp rdf:type owl:DatatypeProperty ;
              rdfs:domain :Situation ;
              rdfs:range xsd:string ;
              rdfs:comment "Where to find the specific moment" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#hasTitle
:hasTitle rdf:type owl:DatatypeProperty ;
          rdfs:domain :Situation ;
          rdfs:range xsd:string ;
          rdfs:comment "Title of the episode" .


#################################################################
#    Classes
#################################################################

###  http://www.loa-cnr.it/ontologies/DUL.owl#Description
dul:Description owl:equivalentClass :Description .


###  http://www.loa-cnr.it/ontologies/DUL.owl#Situation
dul:Situation owl:equivalentClass :Situation .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#AestheticQuality
:AestheticQuality rdf:type owl:Class ;
                  rdfs:subClassOf :HumorQuality ;
                  rdfs:comment "how they are dressed, how they appear" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#Agent
:Agent rdf:type owl:Class ;
       rdfs:subClassOf :HumorEntity ;
       rdfs:comment "Who does the action" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#BehavioralQuality
:BehavioralQuality rdf:type owl:Class ;
                   rdfs:subClassOf :HumorQuality ;
                   rdfs:comment "expressions, strange behaviours" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#Description
:Description rdf:type owl:Class ;
             owl:disjointWith :Situation ;
             rdfs:comment "The description part of all the frames converging to create the humorous situation" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#EthicalRule
:EthicalRule rdf:type owl:Class ;
             rdfs:subClassOf :Description ;
             rdfs:comment "the BEHAVIOURAL rules of the corresponding frame (Social decorum, professionalism, respect)" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#ExpectedSocialFrame
:ExpectedSocialFrame rdf:type owl:Class ;
                     rdfs:subClassOf :Description ;
                     rdfs:comment "the normal social frame (a funeral, a job interview)" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#HumorEntity
:HumorEntity rdf:type owl:Class ;
             rdfs:subClassOf dul:SocialAgent .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#HumorQuality
:HumorQuality rdf:type owl:Class ;
              rdfs:subClassOf dul:Quality ;
              rdfs:comment "This make the blend possibile: through this precise actions the character make the breaking of the social norm funny" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#HumorousFrame
:HumorousFrame rdf:type owl:Class ;
               rdfs:subClassOf :Description ;
               rdfs:comment "This is the BLENDING class, keeping all the descriptions together" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#HumorousSituation
:HumorousSituation rdf:type owl:Class ;
                   rdfs:subClassOf :Situation ;
                   rdfs:comment "The situation BLENDING all the other situations (Social, Norm e Subversive)" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#IncongruityTheory
:IncongruityTheory rdf:type owl:Class ;
                   rdfs:subClassOf :TheoreticalMechanism .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#NormOccurence
:NormOccurence rdf:type owl:Class ;
               rdfs:subClassOf :Situation ;
               rdfs:comment "How the characters apply this norm realated to the frame" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#PhysicalQuality
:PhysicalQuality rdf:type owl:Class ;
                 rdfs:subClassOf :HumorQuality ;
                 rdfs:comment "In what pysical condition the characters are (naked, sweating, dirty)" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#ReliefTheory
:ReliefTheory rdf:type owl:Class ;
              rdfs:subClassOf :TheoreticalMechanism .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#Situation
:Situation rdf:type owl:Class ;
           rdfs:comment "The real description of what happens in the episodes" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#SubversiveFrame
:SubversiveFrame rdf:type owl:Class ;
                 rdfs:subClassOf :Description ;
                 rdfs:comment "Important to note that this is the only element in the description without a corrisponding class in the SItuation, becaue this is just a throretical description of the - already distorted - context the characters live in. In this sense, the whole situation is just an explanation of what we are describing here" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#SubversiveOccurence
:SubversiveOccurence rdf:type owl:Class ;
                     rdfs:subClassOf dul:Action ,
                                     :Situation ;
                     rdfs:comment "The real act of subversion (what are the characters doing)" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#SuperiorityTheory
:SuperiorityTheory rdf:type owl:Class ;
                   rdfs:subClassOf :TheoreticalMechanism .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#Target
:Target rdf:type owl:Class ;
        rdfs:subClassOf :HumorEntity ;
        rdfs:comment "The victim of the joke" .


###  https://github.com/chiarapicardii/itsAlwaysSunnyOntology/blob/main/itsAlwaysSunnyOntology.ttl#TheoreticalMechanism
:TheoreticalMechanism rdf:type owl:Class ;
                      rdfs:comment "This is related to the literature around the construction oh humor" .


