<http://www.loa-cnr.it/ontologies/DUL.owl#Situation> owl:equivalentClass <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Situation> .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#AestheticQuality
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#AestheticQuality> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorQuality> ;
                                                                               rdfs:comment "how they are dressed, how they appear" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Agent
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Agent> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorEntity> ;
                                                                    rdfs:comment "Who does the action" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#BehavioralQuality
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#BehavioralQuality> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorQuality> ;
                                                                                rdfs:comment "expressions, strange behaviours" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Description
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Description> rdf:type owl:Class ;
                                                                          owl:disjointWith <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Situation> ;
                                                                          rdfs:comment "The description part of all the frames converging to create the humorous situation" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#EthicalRule
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#EthicalRule> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Description> ;
                                                                          rdfs:comment "the BEHAVIOURAL rules of the corresponding frame (Social decorum, professionalism, respect)" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#ExpectedSocialFrame
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#ExpectedSocialFrame> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Description> ;
                                                                                  rdfs:comment "the normal social frame (a funeral, a job interview)" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorEntity
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorEntity> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <http://www.loa-cnr.it/ontologies/DUL.owl#SocialAgent> .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorQuality
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorQuality> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <http://www.loa-cnr.it/ontologies/DUL.owl#Quality> ;
                                                                           rdfs:comment "This make the blend possibile: through this precise actions the character make the breaking of the social norm funny" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorousFrame
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorousFrame> rdf:type owl:Class ;
                                                                            rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Description> ;
                                                                            rdfs:comment "This is the BLENDING class, keeping all the descriptions together" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorousSituation
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorousSituation> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Situation> ;
                                                                                rdfs:comment "The situation BLENDING all the other situations (Social, Norm e Subversive)" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#IncongruityTheory
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#IncongruityTheory> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#TheoreticalMechanism> .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#NormOccurence
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#NormOccurence> rdf:type owl:Class ;
                                                                            rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Situation> ;
                                                                            rdfs:comment "How the characters apply this norm realated to the frame" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#PhysicalQuality
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#PhysicalQuality> rdf:type owl:Class ;
                                                                              rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorQuality> ;
                                                                              rdfs:comment "In what pysical condition the characters are (naked, sweating, dirty)" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#ReliefTheory
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#ReliefTheory> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#TheoreticalMechanism> .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Situation
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Situation> rdf:type owl:Class ;
                                                                        rdfs:comment "The real description of what happens in the episodes" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#SubversiveFrame
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#SubversiveFrame> rdf:type owl:Class ;
                                                                              rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Description> ;
                                                                              rdfs:comment "Important to note that this is the only element in the description without a corrisponding class in the SItuation, becaue this is just a throretical description of the - already distorted - context the characters live in. In this sense, the whole situation is just an explanation of what we are describing here" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#SubversiveOccurence
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#SubversiveOccurence> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.loa-cnr.it/ontologies/DUL.owl#Action> ,
                                                                                                  <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Situation> ;
                                                                                  rdfs:comment "The real act of subversion (what are the characters doing)" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#SuperiorityTheory
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#SuperiorityTheory> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#TheoreticalMechanism> .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Target
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Target> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorEntity> ;
                                                                     rdfs:comment "The victim of the joke" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#TheoreticalMechanism
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#TheoreticalMechanism> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Description> ;
                                                                                   rdfs:comment "This is related to the literature around the construction oh humor)" .


