                                                                         rdfs:domain <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorEntity> ;
                                                                         rdfs:range <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorQuality> ;
                                                                         rdfs:comment "connecting HumorQuality to HumorEntity" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#hasTarget
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#hasTarget> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <http://www.loa-cnr.it/ontologies/DUL.owl#hasParticipant> ;
                                                                        owl:inverseOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#isTargetIn> ;
                                                                        rdfs:domain <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#HumorousSituation> ;
                                                                        rdfs:range <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#Target> .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#includes
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#includes> rdf:type owl:ObjectProperty ;
                                                                       owl:inverseOf <http://www.semanticweb.org/lachi/ontologies/2026/nameholder#isIncludedIn> ;
                                                                       rdf:type owl:TransitiveProperty ;
                                                                       rdfs:comment "This is the shape to model the inclusion for the blending, but as i understood is not possibile to use the same property for D&S seeing that one is a construction of a patter and the other of the real application of it" .


###  http://www.semanticweb.org/lachi/ontologies/2026/nameholder#includesDescription
<http://www.semanticweb.org/lachi/ontologies/2026/nameholder#includesDescription> rdf:type owl:ObjectProperty ;
